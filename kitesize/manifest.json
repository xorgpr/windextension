{
  "manifest_version": 3,
  "name": "Kite Helper",
  "version": "1.0",
  "description": "Kite size helper",
  "permissions": ["activeTab", "storage"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.windguru.cz/*"],
      "js": ["utils.js", "windguru.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.windfinder.com/*"],
      "js": ["utils.js", "windfinder.js"],
      "run_at": "document_idle"
    }
  ]
}
