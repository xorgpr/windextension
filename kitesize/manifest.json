{
  "manifest_version": 3,
  "name": "Kite Helper",
  "version": "1.0",
  "description": "Kite size helper",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://www.windguru.com/*"],
      "js": ["windguru.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.windfinder.com/*"],
      "js": ["windfinder.js"],
      "run_at": "document_idle"
    }
  ]
}
